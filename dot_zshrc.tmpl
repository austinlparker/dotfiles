# Basics
autoload -Uz compinit
compinit
autoload -Uz add-zsh-hook

# Cache the Homebrew prefix once (avoids forking `brew --prefix` repeatedly).
BREW_PREFIX="$(brew --prefix)"

# Environment Variables
export GITHUB_USERNAME=austinlparker

# History
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt share_history hist_ignore_all_dups hist_ignore_space hist_verify

# Starship prompt with live light/dark switching.
# starship-theme-sync points ~/.config/starship-active.toml at the right theme;
# STARSHIP_CONFIG tracks that symlink, so the prompt follows macOS appearance.
# dark-notify re-runs the sync on change (one guarded background watcher).
"$HOME/.local/bin/starship-theme-sync"
if command -v dark-notify >/dev/null && ! pgrep -f 'dark-notify -c' >/dev/null; then
  (dark-notify -c "$HOME/.local/bin/starship-theme-sync" &) >/dev/null 2>&1
fi
export STARSHIP_CONFIG="$HOME/.config/starship-active.toml"
eval "$(starship init zsh)"

# Aliases
alias ls='ls --color=auto'
alias ll='ls -la'
alias gs='git status'
alias cat='bat'

# Claude: append personal system prompt on every invocation.
# Re-reads the file each time, so edits take effect without re-sourcing.
if [ -f "$HOME/.claude/system-prompt.md" ]; then
  alias claude='claude --append-system-prompt "$(cat "$HOME/.claude/system-prompt.md")"'
fi

# Functions
glog() {
  git log --oneline --graph --decorate --all
}

# Autojump
[[ -s "$BREW_PREFIX/etc/profile.d/autojump.sh" ]] && . "$BREW_PREFIX/etc/profile.d/autojump.sh"

# Fuzzy Finder (keybindings + completion)
command -v fzf >/dev/null && eval "$(fzf --zsh)"

# ripgrep
if type rg &> /dev/null; then
  export FZF_DEFAULT_COMMAND='rg --files'
  export FZF_DEFAULT_OPTS='-m'
fi

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
[ -s "$HOME/.bun/_bun" ] && source "$HOME/.bun/_bun"

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# go
export PATH="$PATH:$(go env GOPATH)/bin"

# scripts + opencode
export PATH="$PATH:$HOME/scripts"
export PATH="$HOME/.opencode/bin:$PATH"

# skepsis
alias sk="npx --prefix ~/code/skepsis tsx ~/code/skepsis/cli.ts"

# mise (runtime version manager)
eval "$(mise activate zsh)"

# direnv — hooks the dev-profile layer (~/.config/direnv/direnvrc)
eval "$(direnv hook zsh)"

{{ if .isWork -}}
# hnytools (work only)
[ -f ~/.hnytools/hnytools.sh ] && . ~/.hnytools/hnytools.sh
# Claude Code telemetry is routed per-profile by direnv (use_dev_profile), not here.
{{ end -}}

# zsh plugins — sourced LAST. zsh-syntax-highlighting must be the final thing
# sourced so it wraps every widget/alias/function defined above.
source "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "$BREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
