#!/bin/bash
set -e

echo "==> Starting bootstrap..."

# Homebrew
if ! command -v brew &>/dev/null; then
    echo "==> Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
else
    echo "==> Homebrew already installed"
fi

# chezmoi + 1Password must exist BEFORE applying dotfiles, because some managed
# files are templates that read secrets via `op` at apply time. The desktop app
# provides biometric CLI integration (smoother than `op signin`).
#
# Each install is guarded so it's a no-op if the tool/app is already present by
# any means (MDM, manual download, prior brew) — `brew install --cask` errors on
# an unmanaged existing app, which would abort `set -e`.
echo "==> Ensuring chezmoi + 1Password (CLI + desktop)..."
command -v chezmoi >/dev/null || brew install chezmoi
command -v op       >/dev/null || brew install 1password-cli
[ -d "/Applications/1Password.app" ] || brew install --cask 1password

# Clone the dotfiles source without applying yet.
if [ ! -d "$HOME/.local/share/chezmoi" ]; then
    echo "==> Cloning dotfiles..."
    chezmoi init austinlparker
fi

# Gate the apply on 1Password being reachable (templates need it).
echo ""
echo "==> Open 1Password, sign in, and enable Settings → Developer → 'Integrate"
echo "    with 1Password CLI'. (Or run 'eval \$(op signin)' for CLI-only auth.)"
until op account list &>/dev/null && op vault list &>/dev/null; do
    read -r -p "    Press Enter once 1Password CLI is unlocked (Ctrl-C to abort)... "
done
echo "==> 1Password reachable. Applying dotfiles..."
chezmoi apply

# Brewfile (installs everything else, including mise)
echo "==> Installing brew packages..."
brew bundle --file="$HOME/.config/brewfile"

# Runtime versions via mise (NOT pyenv/rbenv/nvm)
if command -v mise &>/dev/null && [ -f "$HOME/.tool-versions" ]; then
    echo "==> Installing mise-managed runtimes..."
    mise install || true
fi

# TPM (Tmux Plugin Manager)
if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
    echo "==> Installing TPM..."
    git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
else
    echo "==> TPM already installed"
fi

# Rust / Bun (not in Brewfile; upstream installers)
command -v rustup &>/dev/null || { echo "==> Installing Rust..."; curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y; source "$HOME/.cargo/env"; }
command -v bun   &>/dev/null || { echo "==> Installing Bun...";  curl -fsSL https://bun.sh/install | bash; }

# macOS system defaults (idempotent)
[ -x "$HOME/.local/bin/macos-defaults" ] && "$HOME/.local/bin/macos-defaults"

echo ""
echo "==> Bootstrap complete!"
echo ""
echo "Manual steps (not automated):"
echo "  1. Open a new terminal to load shell config"
echo "  2. gh auth login"
echo "  3. Install hnytools (work): restores ~/.tool-versions and the ~/.ssh/config managed block"
echo "  4. Restore SSH keys (~/.ssh/id_ed25519, id_rsa) from backup — NOT in dotfiles"
echo "  5. tmux: Ctrl-b I to install plugins"
echo "  6. Per-repo dev profiles: add an '.envrc' with 'use_dev_profile <name>' to each repo"
echo "     (hound/infra: also add .envrc + CLAUDE.local.md to .git/info/exclude), then 'direnv allow'"
echo "  7. Direct-download apps with no cask/MAS: locol, reMarkable desktop, OrcaSlicer, Creality Print"
