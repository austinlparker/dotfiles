#!/bin/bash
set -e

# Usage: bootstrap [--with-repos]
#   --with-repos  also clone + dev-profile the Honeycomb repos (see HONEYCOMB_REPOS
#                 below). Needs gh/SSH auth; skips cleanly if absent, so it's safe
#                 to run 'bootstrap --with-repos' standalone once authed.
WITH_REPOS=0
for arg in "$@"; do
    case "$arg" in
        --with-repos) WITH_REPOS=1 ;;
        -h|--help) echo "Usage: bootstrap [--with-repos]"; exit 0 ;;
        *) echo "bootstrap: unknown option '$arg' (try --with-repos)" >&2; exit 1 ;;
    esac
done

echo "==> Starting bootstrap..."

# Homebrew
if ! command -v brew &>/dev/null; then
    echo "==> Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
else
    echo "==> Homebrew already installed"
fi

# chezmoi + the `op` CLI must exist BEFORE applying dotfiles, because some managed
# files are templates that read secrets via `op` at apply time. Guarded so they're
# no-ops if already present.
#
# The 1Password DESKTOP app is intentionally NOT installed here — it's owned by
# MDM (work) or installed by you, and `brew install --cask` errors on an
# unmanaged existing copy. The op gate below works with either the desktop app's
# biometric integration or a plain `op signin`, however 1Password got there.
echo "==> Ensuring chezmoi + 1Password CLI..."
command -v chezmoi >/dev/null || brew install chezmoi
command -v op       >/dev/null || brew install 1password-cli

# Clone the dotfiles source without applying yet.
if [ ! -d "$HOME/.local/share/chezmoi" ]; then
    echo "==> Cloning dotfiles..."
    chezmoi init austinlparker
fi

# Gate the apply on 1Password being reachable (templates need it).
echo ""
echo "==> Open 1Password, sign in, and enable Settings → Developer → 'Integrate"
echo "    with 1Password CLI'. (Or run 'eval \$(op signin)' for CLI-only auth.)"
until op account list &>/dev/null && op vault list &>/dev/null; do
    read -r -p "    Press Enter once 1Password CLI is unlocked (Ctrl-C to abort)... "
done
echo "==> 1Password reachable. Applying dotfiles..."
chezmoi apply

# Brewfile (installs everything else, including mise)
echo "==> Installing brew packages..."
# Trust our non-official taps before bundling (silences trust warnings; enforced
# if HOMEBREW_REQUIRE_TAP_TRUST is set). Keep in sync with the taps in brewfile.
brew trust --tap cormacrelf/tap goreleaser/tap oven-sh/bun polytoken/tap rwx-cloud/tap terraform-linters/tap
brew bundle --file="$HOME/.config/brewfile"

# Runtime versions via mise (NOT pyenv/rbenv/nvm)
if command -v mise &>/dev/null && [ -f "$HOME/.tool-versions" ]; then
    echo "==> Installing mise-managed runtimes..."
    mise install || true
fi

# TPM (Tmux Plugin Manager)
if [ ! -d "$HOME/.tmux/plugins/tpm" ]; then
    echo "==> Installing TPM..."
    git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
else
    echo "==> TPM already installed"
fi

# Rust (not in Brewfile; upstream installer). Bun is brew-managed (oven-sh/bun).
# --no-modify-path: chezmoi already sources ~/.cargo/env in .zshenv, so rustup
# must not touch shell rcfiles (it errors trying to write them).
command -v rustup &>/dev/null || { echo "==> Installing Rust..."; curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path; source "$HOME/.cargo/env"; }

# macOS system defaults (idempotent)
[ -x "$HOME/.local/bin/macos-defaults" ] && "$HOME/.local/bin/macos-defaults"

# Honeycomb repos (opt-in: bootstrap --with-repos). Cloned from github.com/honeycombio
# into ~/code, each wired to its direnv dev-profile. Add repos as "<name> <profile>".
HONEYCOMB_REPOS=(
    "hound hound"
    "infra infra"
)
if [ "$WITH_REPOS" = 1 ]; then
    # Cloning needs SSH to GitHub (gh auth / restored keys), which may not exist yet
    # on a fresh box — skip cleanly so re-running once authed picks up where it left off.
    if ssh -o BatchMode=yes -o ConnectTimeout=5 -T git@github.com 2>&1 | grep -q 'successfully authenticated'; then
        mkdir -p "$HOME/code"
        for entry in "${HONEYCOMB_REPOS[@]}"; do
            set -- $entry; repo="$1"; profile="$2"; dest="$HOME/code/$repo"
            if [ -d "$dest/.git" ]; then
                echo "==> $repo already cloned"
            else
                echo "==> Cloning honeycombio/$repo..."
                git clone "git@github.com:honeycombio/$repo.git" "$dest" || { echo "    clone failed, skipping"; continue; }
            fi
            # dev-profile envrc + agent notes are local-only; keep them out of the repo's git.
            [ -f "$dest/.envrc" ] || echo "use_dev_profile $profile" > "$dest/.envrc"
            grep -qxF '.envrc' "$dest/.git/info/exclude" 2>/dev/null || printf '.envrc\nCLAUDE.local.md\n' >> "$dest/.git/info/exclude"
            ( cd "$dest" && direnv allow ) 2>/dev/null || true
        done
    else
        echo "==> --with-repos: no SSH access to github.com — skipping repo clone."
        echo "    Run 'gh auth login' (or restore SSH keys), then: bootstrap --with-repos"
    fi
fi

echo ""
echo "==> Bootstrap complete!"
echo ""
echo "Manual steps (not automated):"
echo "  1. Open a new terminal to load shell config"
echo "  2. gh auth login"
echo "  3. Install hnytools (work): restores ~/.tool-versions and the ~/.ssh/config managed block"
echo "  4. Restore SSH keys (~/.ssh/id_ed25519, id_rsa) from backup — NOT in dotfiles"
echo "  5. tmux: Ctrl-b I to install plugins"
echo "  6. Honeycomb repos: re-run 'bootstrap --with-repos' (after gh auth) to clone +"
echo "     dev-profile hound/infra automatically. Other repos: add an '.envrc' with"
echo "     'use_dev_profile <name>', exclude .envrc + CLAUDE.local.md, then 'direnv allow'"
echo "  7. App Store apps (sign in, install from your purchase history — mas can't automate this):"
echo "     1Password for Safari, Base 2, Brother iPrint&Scan, DaisyDisk, Keynote, Numbers,"
echo "     Pages, Pixelmator Pro, Reeder, Xcode, iMovie, keymapp, reMarkable"
echo "  8. Direct-download apps (no cask/App Store): locol, OrcaSlicer, Creality Print"
