{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "honeycomb@honeycomb-plugins": true
  },
  "extraKnownMarketplaces": {
    "otel-tracing": {
      "source": {
        "source": "git",
        "url": "git@tangled.org:aparker.io/otel-claude-code-hooks"
      }
    },
    "cc-conversation-search": {
      "source": {
        "source": "github",
        "repo": "akatz-ai/cc-conversation-search"
      }
    },
    "honeycomb-plugins": {
      "source": {
        "source": "github",
        "repo": "honeycombio/agent-skill"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "verbose": true,
  "teammateMode": "auto",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
