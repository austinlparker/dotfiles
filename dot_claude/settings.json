{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/austinparker/.claude/statusline-command.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "conversation-search@cc-conversation-search": true,
    "honeycomb@honeycomb-plugins": false,
    "skill-creator@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "otel-tracing": {
      "source": {
        "source": "git",
        "url": "git@tangled.org:aparker.io/otel-claude-code-hooks"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "verbose": true,
  "teammateMode": "auto",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
