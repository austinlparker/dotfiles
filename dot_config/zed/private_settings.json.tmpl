// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "diff_view_style": "unified",
  "cli_default_open_behavior": "existing_window",
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "agent_servers": {
    "claude-acp": {
      "favorite_config_option_values": {
        "mode": ["auto", "plan"],
      },
      "default_config_options": {
        "mode": "auto",
      },
      "type": "registry",
    },
  },
  "project_panel": {
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "right",
  },
  "git_panel": {
    "tree_view": false,
    "dock": "right",
  },
  "git": {
    "worktree_directory": ".claude/worktrees",
  },
  "ssh_connections": [
    {
      "host": "tangled-knot",
      "username": "root",
      "projects": [
        {
          "paths": ["~/core"],
        },
      ],
    },
  ],
  "context_servers": {
    "kagi": {
      "command": "uvx",
      "args": ["kagimcp"],
      "env": {
        "KAGI_API_KEY": "{{ onepasswordRead "op://dev/Kagi/credential" "J5G72KN2PVBXBBWCEMQUKLIJHM" }}",
      },
      "settings": {},
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "env": {},
      "settings": {},
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": null,
      "settings": {},
    },
  },
  "agent": {
    "show_turn_stats": true,
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
    },
    "profiles": {
      "write": {
        "name": "Write",
        "tools": {
          "search_web": true,
          "copy_path": true,
          "create_directory": true,
          "create_file": true,
          "delete_path": true,
          "diagnostics": true,
          "edit_file": true,
          "fetch": true,
          "list_directory": true,
          "move_path": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "grep": true,
          "terminal": true,
          "thinking": true,
          "open": true,
        },
        "enable_all_context_servers": true,
        "context_servers": {},
      },
    },
    "default_profile": "ask",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-opus-4-5-thinking-latest",
    },
  },
  "language_models": {
    "ollama": {
      "available_models": [
        {
          "name": "phi4-16k:latest",
          "display_name": "phi4 16k",
          "max_tokens": 16384,
          "supports_tools": false,
        },
        {
          "name": "deepseek-r1:8b",
          "display_name": "deepseek-r1 8b 16k",
          "max_tokens": 16384,
          "supports_tools": false,
        },
      ],
    },
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "GitHub Dark Dimmed",
  },
  "terminal": {
    "font_family": "MesloLGS Nerd Font",
  },
  "languages": {
    "TypeScript": {
      "language_servers": ["!typescript-language-server", "vtsls"],
    },
    "TSX": {
      "language_servers": ["!typescript-language-server", "vtsls"],
    },
    "JavaScript": {
      "language_servers": ["!typescript-language-server", "vtsls"],
    },
    "Markdown": {
      "show_edit_predictions": false,
    },
  },
  "lsp": {
    "pyright": {
      "settings": {
        "python": { "pythonPath": ".venv/bin/python", "venvPath": "." },
      },
    },
  },
}
